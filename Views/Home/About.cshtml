@{
    ViewData["Title"] = "About";
}

<!-- Page wrapper: apply lf-card look and constrain width -->
<div class="about-page-container lf-card">

<!-- Intro section -->
<div class="about-intro mb-4">
    <div class="about-intro__content">
        <h1 class="mb-0 homepage-title homepage-title-styled">
            Cubeflakes Realtor Lease<br>Demo Application
        </h1>
        <div class="about-heading-underline"></div>
        <p class="about-body-text">
            Welcome to the Cubeflakes Realtor Lease Demo Application! This demo application has been
            specifically developed to demonstrate the utilization of BoldSign APIs in the context of lease
            management. The demo is designed from the perspective of Cubeflakes, a fictional real estate
            company, providing you with a practical example of how BoldSign can be integrated into
            real-world leasing processes.
        </p>
        <p class="about-body-text--last">
            This application helps realtors, property managers, landlords, and tenants create, send,
            e-sign, and manage lease agreements digitally with ease, security, and full compliance.
            Experience a seamless digital leasing workflow from document creation to e-signature
            and secure storage.
        </p>
    </div>
    <div class="about-intro__visual">
        <img src="~/images/about-banner.png" alt="Lease Agreement illustration" />
    </div>
</div>

<!-- BoldSign API Key Features Card -->
<div class="about-feature-card">
    <div class="about-feature-card__header">
        <div class="about-feature-card__icon-wrap">
            <i class="bi bi-shield-check"></i>
        </div>
        <h2 class="about-feature-card__title">BoldSign API key features used in this application:</h2>
    </div>
    <div class="about-features-grid">
        <div class="about-feature-item">
            <i class="bi bi-check-circle-fill"></i>
            <span>Single signer</span>
        </div>
        <div class="about-feature-item">
            <i class="bi bi-check-circle-fill"></i>
            <span>Pre-filled form fields</span>
        </div>
        <div class="about-feature-item">
            <i class="bi bi-check-circle-fill"></i>
            <span>Custom branding</span>
        </div>
        <div class="about-feature-item">
            <i class="bi bi-check-circle-fill"></i>
            <span>Embedded signing</span>
        </div>
        <div class="about-feature-item">
            <i class="bi bi-check-circle-fill"></i>
            <span>Templated document</span>
        </div>
        <div class="about-feature-item">
            <i class="bi bi-check-circle-fill"></i>
            <span>Download of signed document</span>
        </div>
        <div class="about-feature-item">
            <i class="bi bi-check-circle-fill"></i>
            <span>Attachment field</span>
        </div>
    </div>
</div>

<!-- Other References Card -->
<div class="about-refs-card">
    <div class="about-refs-card__header">
        <div class="about-refs-card__icon-wrap">
            <i class="bi bi-link-45deg"></i>
        </div>
        <h2 class="about-refs-card__title">Other references:</h2>
    </div>
    <ul class="about-refs-list">
        <li>BoldSign eSignature API: <a href="https://boldsign.com/esignature-api/" target="_blank" rel="noopener">https://boldsign.com/esignature-api/</a></li>
        <li>BoldSign API documentation: <a href="https://developers.boldsign.com/" target="_blank" rel="noopener">https://developers.boldsign.com/</a></li>
        <li>BoldSign demos: <a href="https://demos.boldsign.com/" target="_blank" rel="noopener">https://demos.boldsign.com/</a></li>
    </ul>
</div>

<!-- Sign Up CTA Banner -->
<div class="about-cta-banner">
    <div class="about-cta-banner__left">
        <span class="about-cta-banner__emoji">🎉</span>
        <p class="about-cta-banner__text">This is the right time to create your Free account!</p>
    </div>
    <a href="https://account.boldsign.com/signup?planId=1076" class="btn btn-brand" target="_blank" rel="noopener">Sign Up</a>
    </div>

</div>
