<span class="lf-ln">25</span>      {
<span class="lf-ln">26</span>          <span class="lf-kw">new</span> <span class="lf-cls">Roles</span>
<span class="lf-ln">27</span>          {
<span class="lf-ln">28</span>              <span class="lf-prop">RoleIndex</span> = <span class="lf-num">1</span>,
