<span class="lf-ln"> 9</span>  <span class="lf-kw">var</span> templateClient = <span class="lf-kw">new</span> <span class="lf-cls">TemplateClient</span>(apiClient);
<span class="lf-ln">10</span>  <span class="lf-kw">var</span> documentClient = <span class="lf-kw">new</span> <span class="lf-cls">DocumentClient</span>(apiClient);
<span class="lf-ln">11</span>  
<span class="lf-ln">12</span>  <span class="lf-c">// Sample lease details.</span>
<span class="lf-ln">13</span>  <span class="lf-kw">var</span> tenantName = <span class="lf-str">"Jane Smith"</span>;
<span class="lf-ln">14</span>  <span class="lf-kw">var</span> tenantEmail = <span class="lf-str">"jane@boldsign.dev"</span>;
<span class="lf-ln">15</span>  
