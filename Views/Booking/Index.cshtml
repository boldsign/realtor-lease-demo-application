<span class="lf-ln">17</span>  
<span class="lf-ln">18</span>  <span class="lf-c">// Sample lease details.</span>
<span class="lf-ln">19</span>  <span class="lf-kw">$tenantName</span>  = <span class="lf-str">'Jane Smith'</span>;
<span class="lf-ln">20</span>  <span class="lf-kw">$tenantEmail</span> = <span class="lf-str">'jane@boldsign.dev'</span>;
<span class="lf-ln">21</span>  
<span class="lf-ln">22</span>  <span class="lf-kw">$role</span> = (<span class="lf-kw">new</span> <span class="lf-cls">BoldSign\Model\Roles</span>())
<span class="lf-ln">23</span>      -&gt;<span class="lf-prop">setRoleIndex</span>(<span class="lf-num">1</span>)
<span class="lf-ln">24</span>      -&gt;<span class="lf-prop">setSignerName</span>(<span class="lf-kw">$tenantName</span>)
<span class="lf-ln">25</span>      -&gt;<span class="lf-prop">setSignerEmail</span>(<span class="lf-kw">$tenantEmail</span>)
<span class="lf-ln">26</span>      -&gt;<span class="lf-prop">setSignerType</span>(<span class="lf-str">'Signer'</span>)
<span class="lf-ln">27</span>      -&gt;<span class="lf-prop">setExistingFormFields</span>([
<span class="lf-ln">28</span>          <span class="lf-c">// These IDs must match field IDs in your BoldSign template.</span>
<span class="lf-ln">29</span>          (<span class="lf-kw">new</span> <span class="lf-cls">BoldSign\Model\ExistingFormField</span>())-&gt;<span class="lf-prop">setId</span>(<span class="lf-str">'txtTenant'</span>)-&gt;<span class="lf-prop">setValue</span>(<span class="lf-kw">$tenantName</span>),
<span class="lf-ln">30</span>          (<span class="lf-kw">new</span> <span class="lf-cls">BoldSign\Model\ExistingFormField</span>())-&gt;<span class="lf-prop">setId</span>(<span class="lf-str">'txtHouseAddress'</span>)-&gt;<span class="lf-prop">setValue</span>(<span class="lf-str">'123 Main St'</span>),
<span class="lf-ln">31</span>          (<span class="lf-kw">new</span> <span class="lf-cls">BoldSign\Model\ExistingFormField</span>())-&gt;<span class="lf-prop">setId</span>(<span class="lf-str">'txtMonthlyRent'</span>)-&gt;<span class="lf-prop">setValue</span>(<span class="lf-str">'$2,500.00'</span>),
<span class="lf-ln">32</span>          (<span class="lf-kw">new</span> <span class="lf-cls">BoldSign\Model\ExistingFormField</span>())-&gt;<span class="lf-prop">setId</span>(<span class="lf-str">'txtLeaseTerm'</span>)-&gt;<span class="lf-prop">setValue</span>(<span class="lf-str">'12 months'</span>),
<span class="lf-ln">33</span>      ]);
