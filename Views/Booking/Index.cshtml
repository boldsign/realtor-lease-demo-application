                        @* Python *@
                        <pre class="lf-code-pre lf-code-snippet" id="lf-snippet-python"><code><span class="lf-ln"> 1</span>  <span class="lf-kw">import</span> boldsign
<span class="lf-ln"> 2</span>  
<span class="lf-ln"> 3</span>  <span class="lf-c"># Replace these two values with your BoldSign sandbox values.</span>
<span class="lf-ln"> 4</span>  api_key     = <span class="lf-str">"&lt;YOUR_API_KEY&gt;"</span>
<span class="lf-ln"> 5</span>  template_id = <span class="lf-str">"&lt;YOUR_TEMPLATE_ID&gt;"</span>
<span class="lf-ln"> 6</span>  
<span class="lf-ln"> 7</span>  configuration = boldsign.<span class="lf-cls">Configuration</span>(api_key=api_key)
<span class="lf-ln"> 8</span>  
<span class="lf-ln"> 9</span>  <span class="lf-kw">with</span> boldsign.<span class="lf-cls">ApiClient</span>(configuration) <span class="lf-kw">as</span> api_client:
<span class="lf-ln">10</span>      template_api = boldsign.<span class="lf-cls">TemplateApi</span>(api_client)
<span class="lf-ln">11</span>      document_api = boldsign.<span class="lf-cls">DocumentApi</span>(api_client)
<span class="lf-ln">12</span>  
<span class="lf-ln">13</span>      <span class="lf-c"># Sample lease details.</span>
<span class="lf-ln">14</span>      tenant_name  = <span class="lf-str">"Jane Smith"</span>
<span class="lf-ln">15</span>      tenant_email = <span class="lf-str">"jane@boldsign.dev"</span>
<span class="lf-ln">16</span>  
<span class="lf-ln">17</span>      send_request = boldsign.<span class="lf-cls">SendForSignFromTemplate</span>(
<span class="lf-ln">18</span>          template_id  = template_id,
<span class="lf-ln">19</span>          title        = <span class="lf-str">"Realtor Lease Agreement"</span>,
<span class="lf-ln">20</span>          disable_emails = <span class="lf-kw">True</span>,
<span class="lf-ln">21</span>          roles = [boldsign.<span class="lf-cls">Roles</span>(
<span class="lf-ln">22</span>              role_index   = <span class="lf-num">1</span>,
<span class="lf-ln">23</span>              signer_name  = tenant_name,
<span class="lf-ln">24</span>              signer_email = tenant_email,
<span class="lf-ln">25</span>              signer_type  = <span class="lf-str">"Signer"</span>,
<span class="lf-ln">26</span>              <span class="lf-c"># These IDs must match field IDs in your BoldSign template.</span>
<span class="lf-ln">27</span>              existing_form_fields = [
<span class="lf-ln">28</span>                  boldsign.<span class="lf-cls">ExistingFormField</span>(id=<span class="lf-str">"txtTenant"</span>, value=tenant_name),
<span class="lf-ln">29</span>                  boldsign.<span class="lf-cls">ExistingFormField</span>(id=<span class="lf-str">"txtHouseAddress"</span>, value=<span class="lf-str">"123 Main St"</span>),
<span class="lf-ln">30</span>                  boldsign.<span class="lf-cls">ExistingFormField</span>(id=<span class="lf-str">"txtMonthlyRent"</span>, value=<span class="lf-str">"$2,500.00"</span>),
<span class="lf-ln">31</span>                  boldsign.<span class="lf-cls">ExistingFormField</span>(id=<span class="lf-str">"txtLeaseTerm"</span>, value=<span class="lf-str">"12 months"</span>),
<span class="lf-ln">32</span>              ]
<span class="lf-ln">33</span>          )]
<span class="lf-ln">34</span>      )
<span class="lf-ln">35</span>  
<span class="lf-ln">36</span>      <span class="lf-c"># Create the lease agreement from the template.</span>
<span class="lf-ln">37</span>      document = template_api.<span class="lf-prop">send_using_template</span>(send_request)
<span class="lf-ln">38</span>  
<span class="lf-ln">39</span>      <span class="lf-c"># Generate an embedded signing link for in-app signing.</span>
<span class="lf-ln">40</span>      link = document_api.<span class="lf-prop">get_embedded_sign_link</span>(
<span class="lf-ln">41</span>          document_id  = document.document_id,
<span class="lf-ln">42</span>          signer_email = tenant_email,
<span class="lf-ln">43</span>      )
<span class="lf-ln">44</span>      sign_link = link.sign_link
<span class="lf-ln">45</span>  
<span class="lf-ln">46</span>      <span class="lf-c"># Load sign_link in an iframe in your app.</span>
<span class="lf-ln">47</span>      <span class="lf-c"># &lt;iframe src="{{ sign_link }}" width="100%" height="100%"&gt;&lt;/iframe&gt;</span>
</code></pre>

