@model BookingModel
@{
    ViewData["Title"] = "Lease Application";
    ViewBag.Breadcrumb = new[] {
        new { Text = "Home", Url = "/", Active = false },
        new { Text = Model.PropertyName ?? "Property Details", Url = "/Property/Details", Active = false },
        new { Text = "Lease Application", Url = "#", Active = true }
    };

    ViewBag.BackUrl = "/";
    ViewBag.BackText = "Back to Properties";
}


<div class="lf-wrapper lf-wrapper-wide container mx-auto">

    <div class="lf-header">
        <div>
            <span class="lf-eyebrow">
                <i class="bi bi-house-check"></i>
                Lease Application
            </span>
            <h1 class="lf-title">Ready to move in?</h1>
            <p class="lf-subtitle">
                We’ve prefilled the tenant details for this demo. You can continue with the sample information or update the fields before proceeding. The next step will generate the lease agreement for the selected @Model.PropertyName.
            </p>
        </div>
    </div>

    <div class="row gx-4 align-items-stretch lf-two-col-row">
        <div class="col-12 col-xl-6 d-flex">
            <div class="lf-card d-flex flex-column w-100">
                <form asp-controller="Booking" asp-action="Index" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="PropertyName" />            
                    <input type="hidden" asp-for="ImageUrl" />
                    <input type="hidden" asp-for="Address" />
                    <input type="hidden" asp-for="MonthlyRent" />
                    <input type="hidden" asp-for="Bedrooms" />
                    <input type="hidden" asp-for="Bathrooms" />
                    <input type="hidden" asp-for="Parking" />
                    <input type="hidden" asp-for="LeaseTerm" />
                    <input type="hidden" asp-for="PetPolicy" />
                    <input type="hidden" asp-for="AvailableFrom" />


                    <div class="lf-fields">

                        <div class="lf-field">
                            <label asp-for="FullName" class="lf-label">
                                <i class="bi bi-person"></i>
                                @Html.DisplayNameFor(m => m.FullName)
                            </label>
                            <div class="lf-input-wrap">
                                <input asp-for="FullName"
                                       class="lf-input"
                                       placeholder="Jane Smith"
                                       autocomplete="name" />
                            </div>
                            <span asp-validation-for="FullName" class="lf-error"></span>
                        </div>

                        <div class="lf-field">
                            <label asp-for="Email" class="lf-label">
                                <i class="bi bi-envelope"></i>
                                @Html.DisplayNameFor(m => m.Email)
                            </label>
                            <div class="lf-input-wrap">
                                <input asp-for="Email"
                                       class="lf-input"
                                       placeholder="jane@boldsign.dev"
                                       autocomplete="email" />
                            </div>
                            <span asp-validation-for="Email" class="lf-error"></span>
                        </div>

                        <div class="lf-field">
                            <label asp-for="Phone" class="lf-label">
                                <i class="bi bi-telephone"></i>
                                @Html.DisplayNameFor(m => m.Phone)
                            </label>
                            <div class="lf-input-wrap">
                                <input asp-for="Phone"
                                       class="lf-input"
                                       placeholder="+1 (415) 555-0134"
                                       autocomplete="tel" />
                            </div>
                            <span asp-validation-for="Phone" class="lf-error"></span>
                        </div>

                        <div class="lf-field">
                            <label asp-for="MoveInDate" class="lf-label">
                                <i class="bi bi-calendar3"></i>
                                @Html.DisplayNameFor(m => m.MoveInDate)
                            </label>
                            <div class="lf-input-wrap">
                                <input asp-for="MoveInDate"
                                       class="lf-input"
                                       type="date"
                                       min="@(Model.AvailableFrom != default ? Model.AvailableFrom.ToString("yyyy-MM-dd") : DateTime.Today.ToString("yyyy-MM-dd"))" />
                            </div>
                            <span asp-validation-for="MoveInDate" class="lf-error"></span>
                        </div>

                    </div>

                    <div class="lf-actions">
                        <button type="submit" class="btn btn-brand lf-btn-submit">
                            <i class="bi bi-file-earmark-text me-2"></i>Continue to Lease
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="lf-btn-back">
                            <i class="bi bi-arrow-left me-1"></i>Back to Property
                        </a>
                    </div>

                </form>
            </div>
        </div>

        <div class="col-12 col-xl-6 d-flex lf-code-col">
            <div class="lf-code-panel w-100 d-flex flex-column">

                <div class="lf-code-panel__header">
                    <div class="lf-code-panel__icon-wrap">
                        <i class="bi bi-code-slash"></i>
                    </div>
                    <div>
                        <div class="lf-code-panel__title">Code Example</div>
                        <div class="lf-code-panel__subtitle">API request to create a lease agreement</div>
                    </div>
                </div>

                <div class="lf-code-panel__tabs" id="lf-tabs">
                    <button class="lf-code-tab lf-code-tab--active" data-lang="dotnet" type="button">.NET</button>
                    <button class="lf-code-tab" data-lang="curl" type="button">cURL</button>
                    <button class="lf-code-tab" data-lang="python" type="button">Python</button>
                    <button class="lf-code-tab" data-lang="php" type="button">PHP</button>
                    <button class="lf-code-tab" data-lang="java" type="button">Java</button>
                    <button class="lf-code-tab" data-lang="node" type="button">Node</button>
                </div>

                <div class="lf-code-panel__body flex-grow-1 d-flex flex-column">
                    <div class="lf-code-block flex-grow-1 position-relative">
                        <button class="lf-code-copy-btn" id="lf-copy-btn" type="button" title="Copy code">
                            <i class="bi bi-clipboard me-1"></i>Copy
                        </button>

