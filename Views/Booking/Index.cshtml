<span class="lf-ln"> 4</span>   -H <span class="lf-str">"Content-Type: application/json"</span> \
<span class="lf-ln"> 5</span>   -d <span class="lf-str">'{
<span class="lf-ln"> 6</span>     "title": "Realtor Lease Agreement",
<span class="lf-ln"> 7</span>     "disableEmails": true,
<span class="lf-ln"> 8</span>     "roles": [
<span class="lf-ln"> 9</span>       {
<span class="lf-ln">10</span>         "roleIndex": 1,
<span class="lf-ln">11</span>         "signerName": "Jane Smith",
<span class="lf-ln">12</span>         "signerEmail": "jane@boldsign.dev",
<span class="lf-ln">13</span>         "signerType": "Signer",
<span class="lf-ln">14</span>         "existingFormFields": [
<span class="lf-ln">15</span>           {"id": "txtTenant",      "value": "Jane Smith"},
