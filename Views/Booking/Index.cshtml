<span class="lf-ln">17</span>  {
<span class="lf-ln">18</span>      <span class="lf-prop">TemplateId</span> = templateId,
<span class="lf-ln">19</span>      <span class="lf-prop">Title</span> = <span class="lf-str">"Realtor Lease Agreement"</span>,
<span class="lf-ln">20</span>  
