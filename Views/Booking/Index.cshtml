<span class="lf-ln"> 6</span>  <span class="lf-kw">const</span> <span class="lf-kw">string</span> templateId = <span class="lf-str">"&lt;YOUR_TEMPLATE_ID&gt;"</span>;
<span class="lf-ln"> 7</span>  
