@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            // ── Tab switching ──────────────────────────────────────
            var tabs = document.querySelectorAll('#lf-tabs .lf-code-tab');
            tabs.forEach(function (tab) {
                tab.addEventListener('click', function () {
                    // deactivate all tabs & snippets
                    tabs.forEach(function (t) { t.classList.remove('lf-code-tab--active'); });
                    document.querySelectorAll('.lf-code-snippet').forEach(function (s) {
                        s.classList.remove('lf-code-snippet--active');
                    });

                    // activate clicked tab & matching snippet
                    tab.classList.add('lf-code-tab--active');
                    var lang = tab.getAttribute('data-lang');
                    var snippet = document.getElementById('lf-snippet-' + lang);
                    if (snippet) snippet.classList.add('lf-code-snippet--active');

                    // reset copy button
                    var btn = document.getElementById('lf-copy-btn');
                    if (btn) btn.innerHTML = '<i class="bi bi-clipboard me-1"></i>Copy';
                });
            });

            // ── Copy button ────────────────────────────────────────
            var btn = document.getElementById('lf-copy-btn');
            if (!btn) return;
            btn.addEventListener('click', function () {
                var active = document.querySelector('.lf-code-snippet--active');
                if (!active) return;
                var text = active.innerText || active.textContent || '';
                // strip leading line-number columns (e.g. " 1  " or "10  ")
                text = text.replace(/^\s*\d+\s{1,2}/gm, '').trim();
                navigator.clipboard.writeText(text).then(function () {
                    btn.innerHTML = '<i class="bi bi-check2 me-1"></i>Copied!';
                    setTimeout(function () {
                        btn.innerHTML = '<i class="bi bi-clipboard me-1"></i>Copy';
                    }, 2000);
                });
            });
        })();
    </script>
}
