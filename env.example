# BoldSign API Configuration
# Get your API key from https://app.boldsign.com/settings/apikeys

# Your BoldSign API Key for authentication
REALTORAPIKEY=your_boldsign_api_key_here

# Template ID of your realtore lease application template
# Create a template in BoldSign and copy its ID here
REALTORTEMPLATEID=your_template_id_here

# Your own Brand Logo of your application
# Configure you Customized Brand in BoldSign, Copy Brand Id and replace here
REALTORBRANDID=your_custom_brand_id_here

# Webhook secret key for validating webhook signatures
# Set this in your BoldSign account webhook settings
REALTORWEBHOOKKEY=your_webhook_secret_key_here
